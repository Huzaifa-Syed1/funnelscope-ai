# ── Server ─────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── AI Configuration ──────────────────────────────────
AI_PROVIDER=gemini
AI_MODEL=gemini-2.5-flash-lite

# ── Gemini API (REQUIRED for chat system) ─────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Supabase (Frontend Only) ──────────────────────────
# Configured in HTML (NOT here)
# index.html / auth.html:
#   <meta name="supabase-url" content="https://your-project.supabase.co">
#   <meta name="supabase-key" content="your_anon_key">